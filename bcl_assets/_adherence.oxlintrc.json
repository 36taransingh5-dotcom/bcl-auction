{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/auction/**",
              "components/core/**",
              "ui_kits/auction-platform/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Inter Tight))/i]",
        "message": "Font not provided by the design system. Available: Inter, Inter Tight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|square|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, square, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|status|tone|soft|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, status, tone, soft, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:live|sold|unsold|upcoming)$/]",
        "message": "<Badge> status must be one of 'live' | 'sold' | 'unsold' | 'upcoming'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|pink|green|gold|sky|peach|ink)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'pink' | 'green' | 'gold' | 'sky' | 'peach' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BidHistoryItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:team|amount|accent|key|ref|className|style|children)$/]",
        "message": "<BidHistoryItem> doesn't accept that prop. Declared props: team, amount, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='BidHistoryItem'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:pink|green|gold|sky|peach)$/]",
        "message": "<BidHistoryItem> accent must be one of 'pink' | 'green' | 'gold' | 'sky' | 'peach'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|accent|full|disabled|iconLeft|iconRight|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, accent, full, disabled, iconLeft, iconRight, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|accent|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'accent' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:pink|green|gold|sky|peach)$/]",
        "message": "<Button> accent must be one of 'pink' | 'green' | 'gold' | 'sky' | 'peach'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|pad|radius|interactive|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, pad, radius, interactive, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:surface|canvas|dark|pink|green|gold|sky|peach)$/]",
        "message": "<Card> variant must be one of 'surface' | 'canvas' | 'dark' | 'pink' | 'green' | 'gold' | 'sky' | 'peach'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CountdownTimer'] > JSXAttribute > JSXIdentifier[name!=/^(?:seconds|total|size|label|style|key|ref|className|style|children)$/]",
        "message": "<CountdownTimer> doesn't accept that prop. Declared props: seconds, total, size, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|iconLeft|size|full|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, iconLeft, size, full."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<PlayerStat> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|logo|accent|players|spent|purse|style|onClick|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: name, logo, accent, players, spent, purse, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:pink|green|gold|sky|peach)$/]",
        "message": "<TeamCard> accent must be one of 'pink' | 'green' | 'gold' | 'sky' | 'peach'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
